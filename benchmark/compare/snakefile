# Snakefile

import glob
import os

work_dir = "/home/shuaiw/borg/paper/ipdsummary/ERR12723528_mice_our/"
ref_dir = os.path.join(work_dir, "contigs")
bam_dir = os.path.join(work_dir, "bams")
ipd_sum_dir = os.path.join(work_dir, "ipdSum")



# Function to get sample names after split_bam rule
def get_samples():
    bam_files = glob.glob(os.path.join(work_dir, "contigs", "*.fa"))
    samples = list(set(f.split("/")[-1].replace(".fa", "") for f in bam_files))
    # print (f"there are {len(samples)} samples to load ipd...")
    return samples

rule all:
    input:
        expand(os.path.join(ipd_sum_dir, "{sample}.out.pickle"), sample=get_samples())

rule ipdSum:
    input:
        align_bam=os.path.join(work_dir, "bams", "{sample}.bam"),
        ref=os.path.join(work_dir, "contigs", "{sample}.fa"),
    output:
        os.path.join(ipd_sum_dir, "{sample}.out.pickle")
    shell:
        """
        bash /home/shuaiw/Methy/benchmark/compare/run_ipdSummary.sh {input.align_bam} {input.ref} {ipd_sum_dir}/{wildcards.sample}
        """
