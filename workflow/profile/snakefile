# Snakefile

import glob
import os


configfile: "../config.yaml"

whole_bam = config["whole_bam"]
whole_ref = config["whole_ref"]
work_dir = config["work_dir"]


# Create required directories dynamically
sub_dirs=[".", "profiles"]
for sub in sub_dirs:
    os.makedirs(os.path.join(work_dir, sub), exist_ok=True)


# Function to get sample names after split_bam rule
def get_samples():
    gff_files = [f for f in glob.glob(os.path.join(work_dir, "gffs",  "*.gff")) if "reprocess" not in f]
    samples = list(set(f.split("/")[-1].replace(".gff", "") for f in gff_files))
    print (f"there are {len(samples)} samples to profile motif...")
    return samples

rule all:
    input:
        expand(os.path.join(work_dir, "profiles", "{sample}.motifs.profile.csv"), sample=get_samples()),
        os.path.join(work_dir, "motif_profile.csv")
        # os.path.join(work_dir, "motif_heatmap.pdf")

rule collect:
    input:
        os.path.join(work_dir, "motifs")
    output:
        os.path.join(work_dir, "all.motifs.csv")
    shell:
        """
        set -euo pipefail
        python /home/shuaiw/Methy/collect_motifs.py {input} {output} 
        """

rule profiling:
    input:
        ref=os.path.join(work_dir, "contigs", "{sample}.fa"),
        gff=os.path.join(work_dir, "gffs", "{sample}.gff"),
        all_motifs=os.path.join(work_dir, "all.motifs.csv"),
    output:
        prof=os.path.join(work_dir, "profiles", "{sample}.motifs.profile.csv"),
    shell:
        """
        set -euo pipefail
        python /home/shuaiw/Methy/motif_profile.py {input.ref} {input.gff} {input.all_motifs} {output.prof}
        """

rule merge_profiles:
    input:
        prof=os.path.join(work_dir, "profiles"),
        prof2=expand(os.path.join(work_dir, "profiles", "{sample}.motifs.profile.csv"),
               sample=get_samples())
    output:
        heatmap=os.path.join(work_dir, "motif_heatmap.pdf"),
        merged=os.path.join(work_dir, "motif_profile.csv")
    shell:
        """
        set -euo pipefail
        python /home/shuaiw/Methy/merge_profile.py --all_profiles {input.prof} \
        --heatmap  {output.heatmap} \
        --summary {output.merged}
        """
