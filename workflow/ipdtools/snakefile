# Snakefile

import glob
import os

configfile: "../config.yaml"

whole_bam = config["whole_bam"]
whole_ref = config["whole_ref"]
work_dir = config["work_dir"]

# Create required directories dynamically
sub_dirs=[".", "ipd", "model", "control"]
for sub in sub_dirs:
    os.makedirs(os.path.join(work_dir, sub), exist_ok=True)




# Function to get sample names after split_bam rule
def get_samples():
    bam_files = glob.glob(os.path.join(work_dir, "bams", "*.bam"))
    samples = list(set(f.split("/")[-1].replace(".bam", "") for f in bam_files))
    print (len(samples), "samples")
    return samples

rule all:
    input:
        # expand(f"{work_dir}/ipd_ratio/{{sample}}.ipd3.csv", sample=get_samples())
        expand(os.path.join(work_dir, "control", "{sample}.ipd2.csv"), sample=get_samples())

rule ipd_tools:
    input:
        raw=os.path.join(work_dir, "ipd", "{sample}.ipd1.csv"),
        ref=os.path.join(work_dir, "contigs", "{sample}.fa")
    output:
        model_value = os.path.join(work_dir, "model", "{sample}.model.csv"),
        ipd = os.path.join(work_dir, "control", "{sample}.ipd2.csv"),
    threads: 2
    shell:
        """
        set -euo pipefail
        ipdtools -f {input.ref} -o {output.model_value} --nproc {threads} --indexing 0
        python /home/shuaiw/Methy/match_model_control.py {input.raw} {output.model_value} {output.ipd}
        """