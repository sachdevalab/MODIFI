# Snakefile

import glob
import os


configfile: "../config.yaml"

whole_bam = config["whole_bam"]
whole_ref = config["whole_ref"]
work_dir = config["work_dir"]
min_score = config["min_score"]
min_cov = config["min_cov"]


# Create required directories dynamically
sub_dirs=[".", "motifs","segs"]
for sub in sub_dirs:
    os.makedirs(os.path.join(work_dir, sub), exist_ok=True)


# Function to get sample names after split_bam rule
def get_samples():
    # bam_files = glob.glob(os.path.join(work_dir, "ipd_ratio", "*.ipd3.csv"))
    gff_files = [f for f in glob.glob(os.path.join(work_dir, "gffs",  "*.gff")) if "reprocess" not in f]
    samples = list(set(f.split("/")[-1].replace(".gff", "") for f in gff_files))
    print (f"there are {len(samples)} samples to identify motif...")
    return samples

rule all:
    input:
        expand(os.path.join(work_dir, "motifs", "{sample}.motifs.csv"), sample=get_samples())

rule seg:
    input:
        gff=os.path.join(work_dir, "gffs", "{sample}.gff"),
        ref=os.path.join(work_dir, "contigs", "{sample}.fa"),
        bam=os.path.join(work_dir, "bams", "{sample}.bam")
    output:
        seg_ref=os.path.join(work_dir, "segs", "{sample}.seg.fa"),
        seg_gff=os.path.join(work_dir, "segs", "{sample}.seg.gff"),
    shell:
        """
        set -euo pipefail
        samtools depth -aa {input.bam} > {input.bam}.depth
        python /home/shuaiw/Methy/segment_genome.py {input.bam}.depth {input.ref} {input.gff} {output.seg_ref} {output.seg_gff}
        """

rule ipd_ratio:
    input:
        gff=os.path.join(work_dir, "segs", "{sample}.seg.gff"),
        ref=os.path.join(work_dir, "segs", "{sample}.seg.fa"),
        bam=os.path.join(work_dir, "bams", "{sample}.bam")
    output:
        os.path.join(work_dir, "motifs", "{sample}.motifs.csv"),
    threads: 2
    params:
        min_score=min_score
    shell:
        """
        set -euo pipefail
        /home/shuaiw/smrtlink/motifMaker find -f {input.ref} -g {input.gff} -o {output} -j {threads} -m {params.min_score}
        """

