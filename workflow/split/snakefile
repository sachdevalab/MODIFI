# Snakefile

import glob
import os

configfile: "../config.yaml"

whole_bam = config["whole_bam"]
whole_ref = config["whole_ref"]
work_dir = config["work_dir"]
min_contig_len = config["min_len"]
max_NM=config["max_NM"]

# Create required directories dynamically
sub_dirs=[".", "ipd", "control", "bams", "contigs"]
for sub in sub_dirs:
    os.makedirs(os.path.join(work_dir, sub), exist_ok=True)

rule split_bam:
    input:
        whole_bam = f"{whole_bam}",
        whole_ref = f"{whole_ref}",
        work_dir = f"{work_dir}"
    output:
        touch(os.path.join(work_dir, "split_bam_done.txt"))
    threads: 100
    params:
        min_len=min_contig_len,
        max_NM=max_NM
    shell:
        """
        set -euo pipefail
        python /home/shuaiw/Methy/split_bam.py --bam {input.whole_bam} \
        --whole_ref {input.whole_ref} --work_dir {input.work_dir} --threads {threads} \
        --min_len {params.min_len} --max_NM {params.max_NM}
        touch {output}
        """

