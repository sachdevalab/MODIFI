# Snakefile

import glob
import os


configfile: "../config.yaml"

whole_bam = config["whole_bam"]
whole_ref = config["whole_ref"]
work_dir = config["work_dir"]
min_cov = config["min_cov"]


# Create required directories dynamically
sub_dirs=[".", "ipd", "control", "ipd_ratio", "bams", "contigs", "gffs", "figs"]
for sub in sub_dirs:
    os.makedirs(os.path.join(work_dir, sub), exist_ok=True)


# Function to get sample names after split_bam rule
def get_samples():
    bam_files = glob.glob(os.path.join(work_dir, "bams", "*.bam"))
    samples = list(set(f.split("/")[-1].replace(".bam", "") for f in bam_files))
    print (f"there are {len(samples)} samples to compare IPD ratio...")
    return samples

rule all:
    input:
        # expand(f"{work_dir}/ipd_ratio/{{sample}}.ipd3.csv", sample=get_samples())
        expand(os.path.join(work_dir, "ipd_ratio", "{sample}.ipd3.csv"), sample=get_samples()),
        expand(os.path.join(work_dir, "figs", "{sample}.png"), sample=get_samples())

rule ipd_ratio:
    input:
        control=os.path.join(work_dir, "control", "{sample}.ipd2.csv"),
        ref=os.path.join(work_dir, "contigs", "{sample}.fa")
    output:
        ipd = os.path.join(work_dir, "ipd_ratio", "{sample}.ipd3.csv"),
        gff = os.path.join(work_dir, "gffs", "{sample}.gff"),
        fig = os.path.join(work_dir, "figs", "{sample}.png"),
    params:
        min_cov = min_cov
    shell:
        """
        set -euo pipefail
        python /home/shuaiw/Methy/comp_ipd_ratio.py {input.control} {output.ipd} {output.gff} {input.ref} {output.fig} {params.min_cov}
        """
