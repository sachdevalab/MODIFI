# Snakefile

###  sbatch --partition standard --wrap "snakemake " --job-name=map

import glob
import os

input_bam = "/home/shuaiw/borg/XRSBK_20221007_S64018_PL100268287-1_C01.ccs.bam"
ref = "/home/shuaiw/borg/contigs/mis_contigs.fasta"
outbam = "/home/shuaiw/borg/mis_assembly/align.ccs.bam"

rule all:
    input:
        outbam,
        outbam + ".bai",
        outbam + ".pbi"

rule pbmm2:
    input:
        # split_done=os.path.join(work_dir, "split_bam_done.txt"),  # Ensures `split_bam` runs first
        input_bam=input_bam,
        ref=ref
    output:
        outbam=outbam,
        outbam_index=outbam + ".bai",
        outbam_pbi=outbam + ".pbi"
    shell:
        """~/smrtlink/pbmm2 align {input.ref} {input.input_bam} {output.outbam} \
            --preset CCS -j 64 --sort -J 64
            samtools index {output.outbam}
            /home/shuaiw/smrtlink/pbindex {output.outbam}
         """
