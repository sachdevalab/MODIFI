# Snakefile

import glob
import os

configfile: "config.yaml"

whole_bam = config["whole_bam"]
whole_ref = config["whole_ref"]
work_dir = config["work_dir"]
maxAlignments = config.get("maxAlignments", 10000)  # Default value if not set in config
read_type = config.get("read_type", "subreads")  # Default value if not set in config
# max_NM = config.get("max_NM", 3)  # Default value if not set in config
min_contig_len = config.get("min_len", 50000)  # Default value if not set in config
kmer_mean_db = config["kmer_mean_db"]
kmer_num_db = config["kmer_num_db"]
min_cov = config["min_cov"]
clean_flag = config.get("clean", True)
min_frac = config["min_frac"]
min_sites = config["min_sites"]
min_score = config["min_score"]

if not config.get("max_NM"):
    if config["read_type"] == "hifi" or config["read_type"] == "ccs":
        config["max_NM"] = 200
    elif config["read_type"] == "subreads":
        config["max_NM"] = 1000
    else:
        # Either provide a default or raise an error
        # if config["x"] is something unexpected.
        ## report errot
        raise ValueError("Unknown value for read_type: {}".format(config["read_type"]))

max_NM = config.get("max_NM")

print (whole_bam)
print (whole_ref)
print (work_dir)
print ("clean_flag: ", clean_flag)

## create work_dir
os.makedirs(work_dir, exist_ok=True)

rule all:
    input:
        os.path.join(work_dir, "split_done.txt"),
        os.path.join(work_dir, "load_done.txt"),
        # os.path.join(work_dir, "remove_empty_done.txt"),
        os.path.join(work_dir, "control_done.txt"),
        os.path.join(work_dir, "compare_done.txt"),
        os.path.join(work_dir, "motif_done.txt"),
        os.path.join(work_dir, "profile_done.txt"),
        os.path.join(work_dir, "clean_done.txt"),

rule split:
    input:
    output:
        # touch(os.path.join(work_dir, "split_done.txt"))
        os.path.join(work_dir, "split_done.txt")
    params:
        min_len=min_contig_len,
        max_NM=max_NM
    shell:
        """
        cd split 
        /usr/bin/time -v -o {output} snakemake --config whole_bam={whole_bam} whole_ref={whole_ref} work_dir={work_dir} min_len={params.min_len} max_NM={params.max_NM}
        cd ..
        """

rule load:
    input:
        os.path.join(work_dir, "split_done.txt")
    output:
        os.path.join(work_dir, "load_done.txt")
    params:
        maxAlignments=maxAlignments,
        read_type=read_type,
        max_NM=max_NM
    shell:
        """
        cd load 
        /usr/bin/time -v -o {output} snakemake --config whole_bam={whole_bam} whole_ref={whole_ref} work_dir={work_dir}\
        maxAlignments={params.maxAlignments} read_type={params.read_type} max_NM={params.max_NM}
        cd ..
        """

# rule remove_empty:
#     input:
#         one=os.path.join(work_dir, "load_done.txt"),
#     output:
#         os.path.join(work_dir, "remove_empty_done.txt")
#     shell:
#         """
