#         """

rule control:
    input:
        os.path.join(work_dir, "load_done.txt")
        # os.path.join(work_dir, "remove_empty_done.txt")
    output:
        os.path.join(work_dir, "control_done.txt")
    shell:
        """
        cd control 
        /usr/bin/time -v -o {output} snakemake --config whole_bam={whole_bam}\
         whole_ref={whole_ref} work_dir={work_dir} kmer_mean_db={kmer_mean_db} kmer_num_db={kmer_num_db}
        cd ..
        """ 

rule compare:
    input:
        os.path.join(work_dir, "control_done.txt")
    output:
        os.path.join(work_dir, "compare_done.txt")
    params:
        min_cov = min_cov
    shell:
        """
        cd compare 
        /usr/bin/time -v -o {output} snakemake --config whole_bam={whole_bam} whole_ref={whole_ref} work_dir={work_dir} min_cov={params.min_cov}
        cd ..
        """

rule motif:
    input:
        os.path.join(work_dir, "compare_done.txt")
    output:
        os.path.join(work_dir, "motif_done.txt")
    params:
        min_score = min_score
    shell:
        """
        cd motif 
        /usr/bin/time -v -o {output} snakemake --config whole_bam={whole_bam} whole_ref={whole_ref} work_dir={work_dir} min_score={params.min_score}
        cd ..
        """

rule profile:
    input:
        os.path.join(work_dir, "motif_done.txt")
    output:
        os.path.join(work_dir, "profile_done.txt")
    params:
        min_frac=min_frac,
        min_sites=min_sites,
        min_score = min_score
    shell:
        """
        cd profile 
        /usr/bin/time -v -o {output} snakemake --config whole_bam={whole_bam} whole_ref={whole_ref} work_dir={work_dir} min_frac={params.min_frac} min_sites={params.min_sites} min_score={params.min_score}
        cd ..
        """

rule clean_tmp:
    input:
        os.path.join(work_dir, "profile_done.txt")
    output:
        os.path.join(work_dir, "clean_done.txt")
    params:
        clean_flag = clean_flag
    shell:
        """
        if [ "{params.clean_flag}" = "True" ]; then
            rm -rf {work_dir}/bams
            rm -rf {work_dir}/contigs
            rm -rf {work_dir}/ipds
        fi
        touch {output}
        """
