# Snakefile

import glob
import os

configfile: "../config.yaml"

whole_bam = config["whole_bam"]
whole_ref = config["whole_ref"]
work_dir = config["work_dir"]
maxAlignments = config.get("maxAlignments", 10000)  # Default value if not set in config
read_type = config.get("read_type", "subreads")  # Default value if not set in config
max_NM = config.get("max_NM", 3)  # Default value if not set in config



# Create required directories dynamically
sub_dirs=[".", "ipd", "control", "bams", "contigs"]
for sub in sub_dirs:
    os.makedirs(os.path.join(work_dir, sub), exist_ok=True)

# Function to get sample names after split_bam rule
def get_samples():
    bam_files = glob.glob(os.path.join(work_dir, "contigs", "*.fa"))
    samples = list(set(f.split("/")[-1].replace(".fa", "") for f in bam_files))
    print (f"there are {len(samples)} samples to load ipd...")
    return samples

rule all:
    input:
        expand(os.path.join(work_dir, "ipd", "{sample}.count"), sample=get_samples())

rule load_ipd:
    input:
        # split_done=os.path.join(work_dir, "split_bam_done.txt"),  # Ensures `split_bam` runs first
        bam=os.path.join(work_dir, "bams", "{sample}.bam"),
        ref=os.path.join(work_dir, "contigs", "{sample}.fa"),
    output:
        os.path.join(work_dir, "ipd", "{sample}.count")
    params:
        maxAlignments=maxAlignments,
        read_type=read_type
    shell:
        """
        python /home/shuaiw/Methy/standard_load7.py --bam {input.bam} \
        --ref {input.ref} -o {output} --maxAlignments {params.maxAlignments} --read_type {read_type} --max_NM {max_NM}
        """
