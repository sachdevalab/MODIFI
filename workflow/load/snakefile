# Snakefile

import glob
import os

configfile: "../config.yaml"

whole_bam = config["whole_bam"]
whole_ref = config["whole_ref"]
work_dir = config["work_dir"]
maxAlignments = config.get("maxAlignments", 10000)  # Default value if not set in config



# Create required directories dynamically
sub_dirs=[".", "ipd", "control", "bams", "contigs"]
for sub in sub_dirs:
    os.makedirs(os.path.join(work_dir, sub), exist_ok=True)

# Function to get sample names after split_bam rule
def get_samples():
    bam_files = glob.glob(os.path.join(work_dir, "bams", "*.bam"))
    samples = list(set(f.split("/")[-1].replace(".bam", "") for f in bam_files))
    print (samples)
    return samples

rule all:
    input:
        expand(os.path.join(work_dir, "ipd", "{sample}.ipd1.csv"), sample=get_samples())

rule load_ipd:
    input:
        # split_done=os.path.join(work_dir, "split_bam_done.txt"),  # Ensures `split_bam` runs first
        bam=os.path.join(work_dir, "bams", "{sample}.bam"),
        ref=os.path.join(work_dir, "contigs", "{sample}.fa"),
    output:
        os.path.join(work_dir, "ipd", "{sample}.ipd1.csv")
    params:
        maxAlignments=maxAlignments
    shell:
        """
        python /home/shuaiw/Methy/standard_load7.py {input.bam} {input.ref} {output} {params.maxAlignments}
        """
